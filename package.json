{
  "name": "throughline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "scribe": "tsx src/cli/scribe-cli.ts",
    "server": "tsx src/server/server.ts",
    "dev:web": "vite",
    "dev": "concurrently -k -n server,web \"OPEN=0 npm:server\" \"npm:dev:web\"",
    "build:web": "vite build",
    "start": "npm run build:web && tsx src/server/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@hono/node-server": "^2.0.4",
    "chokidar": "^4.0.1",
    "diff": "^7.0.0",
    "hono": "^4.12.23",
    "open": "^11.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.3",
    "vitest": "^3.0.0"
  }
}
